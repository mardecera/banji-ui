{
	"name": "banji-ui",
	"version": "0.0.10-beta.0",
	"type": "module",
	"files": ["dist"],
	"main": "./dist/banji-ui.umd.cjs",
	"module": "./dist/banji-ui.js",
	"exports": {
		".": {
			"import": "./dist/banji-ui.js",
			"require": "./dist/banji-ui.umd.cjs"
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"biome": "biome check ./src",
		"biome:w": "biome check --write ./src",
		"storybook": "storybook dev -p 6006",
		"storybook:b": "storybook build",
		"test": "vitest",
		"test:run": "vitest run",
		"test:ui": "vitest --ui"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@chromatic-com/storybook": "^4.0.0",
		"@storybook/addon-a11y": "9.0.8",
		"@storybook/addon-docs": "9.0.8",
		"@storybook/addon-vitest": "9.0.8",
		"@storybook/react-vite": "9.0.8",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^24.0.0",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@vitejs/plugin-react-swc": "^3.9.0",
		"@vitest/browser": "^3.2.3",
		"@vitest/coverage-v8": "^3.2.3",
		"globals": "^16.0.0",
		"jsdom": "^26.1.0",
		"lefthook": "^1.11.13",
		"playwright": "^1.53.0",
		"storybook": "9.0.8",
		"typescript": "~5.8.3",
		"vite": "^6.3.5",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^3.2.3"
	},
	"author": "Jonathan Alarcón",
	"repository": {
		"type": "git",
		"url": "https://github.com/mardecera/banji-ui.git"
	}
}
